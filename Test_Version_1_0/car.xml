<mujoco model="single tire">
  <compiler angle="radian"/>

  <worldbody>
    <!-- 地面用于参考 -->
    <geom name="floor" type="plane" size="0 0 0.05" rgba="0.3 0.4 0.7 1"/>

    <!-- 轮胎 -->
    <body name="tire" pos="0 0 0.2">   <!-- 放在离地 0.2m 处 -->
      <!-- 圆柱几何体：半径 0.15m，半长 0.05m（即厚 0.1m） -->
      <!-- euler="0 1.5708 0" 表示绕 Y 轴旋转 90°（1.5708 rad = π/2），
           这样圆柱的轴线变成 Y 轴，圆形面朝前/后，看上去像轮胎 -->
      <geom name="tire_geom"
            type="cylinder"
            size="0.15 0.05"
            rgba="0.2 0.2 0.2 1"
            euler="0 1.5708 0"/>
    </body>
  </worldbody>
</mujoco>